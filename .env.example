# ── RAG-MCwiki 环境变量配置 ──
# 复制此文件为 .env 并按需修改

# Bot API 认证密钥（未设置则跳过认证）
# BOT_API_KEY=

# 嵌入模型 ID（可选值: yuan2-hf, qwen3-hf, jasper-hf, qwen3-gguf, gte-quant）
EMBEDDING_MODEL_ID=yuan2-hf

# 本地 LLM 地址（LM Studio）
LOCAL_LLM_URL=http://localhost:1234/v1

# 云端 LLM 地址（DeepSeek）
DEEPSEEK_API_URL=https://api.deepseek.com

# 检索返回的文档数量
RETRIEVAL_K=20

# 嵌入批处理大小（8GB 显存建议 8-16，12GB+ 可设 32-64）
EMBEDDING_BATCH_SIZE=32

# 分块字符数（0=使用模型预设值，手动设置会覆盖预设）
EMBEDDING_CHUNK_SIZE=0

# 目标 Token 数（RAG 建议 500 左右，系统会自动调整 chunk_size 以逼近此值）
EMBEDDING_TARGET_TOKENS=500

# 嵌入 Token 目标利用率（0.0~1.0，建议 0.90~0.95）
EMBEDDING_TOKEN_TARGET_UTILIZATION=0.95

# ── BM25 混合检索 ──
# 是否启用 BM25+RRF 混合检索（false 则使用原有关键词启发式逻辑）
BM25_ENABLED=true
# BM25 词频饱和参数（越大对高频词越敏感，典型范围 1.2-2.0）
BM25_K1=1.5
# BM25 文档长度归一化（0=不归一化，1=完全按长度惩罚长文档）
BM25_B=0.75
# BM25 每次返回的最大文档数
BM25_TOP_K=20
# Reciprocal Rank Fusion 常数（标准值 60，越大排名差异越小，典型范围 30-100）
RRF_K=60

# ── 召回控制 ──
# 召回片段总字数上限（按相关性排序逐条累加直到此值）
MAX_CONTEXT_CHARS=7000
# LLM 查询改写的搜索词数量（不含原始查询，总召回 ≈ (此值+1) × RETRIEVAL_K）
QUERY_REWRITE_COUNT=3
# 查询改写 LLM 超时秒数（超时则退回原始查询）
QUERY_REWRITE_TIMEOUT=5.0
# 同一标题最多保留的 chunk 条数（防止单页面占满结果）
PER_TITLE_CAP=3

# ── 重排序加成系数（RRF 模式）──
# 标题精确匹配加成（搜索词 == 标题）
TITLE_EXACT_BOOST=0.01
# 标题子串匹配加成（搜索词 ⊂ 标题）
TITLE_SUBSTR_BOOST=0.005
# 概述页加成（非快照/预发布/RC/子页面，概述页通常更完整）
OVERVIEW_BOOST_RRF=0.003
# 原始查询短语匹配加成（文档包含原始查询关键词时加分，弥补 BM25-only 文档的 RRF 劣势）
QUERY_PHRASE_BOOST=0.025

# ── 重排序加成系数（关键词模式，非 BM25 时生效）──
# 概述页加成（整数分制）
OVERVIEW_BOOST_KEYWORD=6
# 标题精确匹配加成
KEYWORD_TITLE_EXACT_BOOST=10
# 标题子串匹配加成
KEYWORD_TITLE_SUBSTR_BOOST=5
# 内容匹配加成
KEYWORD_CONTENT_BOOST=1

# ── 短语匹配停用词（逗号分隔，不参与 QUERY_PHRASE_BOOST 加成）──
PHRASE_STOP_WORDS=版本,什么,哪个,哪些,怎么,如何,为什么,可以,不能,失效,更新,获取,使用
